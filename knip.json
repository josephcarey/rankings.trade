{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["src/api/app.ts"],
  "project": ["src/**/*.{svelte,ts}", "*.{js,ts}"],
  "ignoreDependencies": [
    "@fontsource-variable/inter",
    "open-props",
    "svelte",
    "vite",
    "eslint",
    "prettier",
    "svelte-check",
    "wrangler"
  ],
  "ignoreExportsUsedInFile": true,
  "vitest": {
    "config": ["vite.config.ts"]
  },
  "svelte": {
    "entry": "src/**/*.svelte"
  }
}
