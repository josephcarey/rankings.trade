{
  "name": "rankings.trade",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "A competitive leaderboard for SpaceTraders agents.",
  "license": "MIT",
  "scripts": {
    "build": "vite build",
    "check": "svelte-check --tsconfig ./tsconfig.json && tsc --noEmit && knip && eslint . && bun audit",
    "ci": "bun run check && bun run test",
    "db:migrate": "bun scripts/db-migrate.ts",
    "dev": "vite dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview",
    "test": "vitest run --coverage",
    "test:watch": "bun --bun vitest",
    "prepare": "svelte-kit sync"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.65.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "hono": "^4.12.25",
    "open-props": "^1.7.23",
    "svelte": "^5.56.3",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260611.1",
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.14",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "eslint-plugin-depend": "^1.5.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-svelte": "^3.19.0",
    "eslint-plugin-unicorn": "^65.0.1",
    "globals": "^17.6.0",
    "knip": "^6.16.1",
    "prettier": "^3.8.4",
    "svelte-check": "^4.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8",
    "wrangler": "^4.100.0"
  },
  "overrides": {
    "cookie": "^1.1.1"
  }
}
